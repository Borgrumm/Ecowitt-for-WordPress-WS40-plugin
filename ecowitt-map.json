{
  "schema_version": 1,
  "name": "Ecowitt generic raw-to-metric alias map",
  "generated_at_utc": "2026-07-07T17:42:18Z",
  "target_locale": "fr-FR",
  "purpose": "Map Ecowitt custom-server raw POST keys to stable metric names, with dynamic sensor families and unknown raw key detection.",
  "format_notes": [
    "The first source present and numeric should normally win unless the script explicitly implements source_strategy.",
    "Most Ecowitt custom-server rain values are sent in inches; piezo rain keys are also treated as inches in observed payloads.",
    "Keys can vary with gateway, firmware, protocol and paired sensors. Do not use model/stationtype alone as the decoding authority.",
    "This map is intentionally generous: some keys are from Ecowitt custom upload examples, Home Assistant/Ecowitt integrations and gateway API field names. Unknown-key logging remains important."
  ],
  "units": {
    "C": "degree Celsius",
    "F": "degree Fahrenheit",
    "hPa": "hectopascal",
    "inHg": "inch of mercury",
    "km/h": "kilometre per hour",
    "mph": "mile per hour",
    "m/s": "metre per second",
    "mm": "millimetre",
    "inch": "inch",
    "mm/h": "millimetre per hour",
    "inch/h": "inch per hour",
    "%": "percent",
    "deg": "degree",
    "W/m2": "watt per square metre",
    "lux": "lux",
    "kPa": "kilopascal",
    "ppm": "parts per million",
    "ug/m3": "microgram per cubic metre",
    "V": "volt",
    "raw": "raw Ecowitt value",
    "bool01": "0 or 1 boolean-like value",
    "unix_s": "Unix timestamp in seconds",
    "s": "seconds"
  },
  "profile": {
    "output_key": "profile",
    "metadata_fields": {
      "gateway_model": {
        "source": "model",
        "type": "string"
      },
      "stationtype": {
        "source": "stationtype",
        "type": "string"
      },
      "station_firmware_from_stationtype": {
        "source": "stationtype",
        "type": "regex",
        "pattern": "_V(?<version>[0-9.]+)"
      },
      "station_time_utc": {
        "source": "dateutc",
        "type": "datetime_string"
      },
      "gateway_runtime_s": {
        "source": "runtime",
        "type": "number",
        "unit": "s"
      },
      "gateway_heap_bytes": {
        "source": "heap",
        "type": "integer",
        "unit": "bytes"
      },
      "rf_frequency": {
        "source": "freq",
        "type": "string"
      },
      "upload_interval_s": {
        "source": "interval",
        "type": "integer",
        "unit": "s"
      }
    },
    "feature_rules": [
      {
        "name": "gateway_gw3000",
        "match_any_regex": [
          {
            "key": "model",
            "pattern": "GW3000|GW3010"
          },
          {
            "key": "stationtype",
            "pattern": "GW3000|GW3010"
          }
        ]
      },
      {
        "name": "gateway_gw2000",
        "match_any_regex": [
          {
            "key": "model",
            "pattern": "GW2000"
          },
          {
            "key": "stationtype",
            "pattern": "GW2000"
          }
        ]
      },
      {
        "name": "gateway_gw1000_1100",
        "match_any_regex": [
          {
            "key": "model",
            "pattern": "GW1000|GW1100"
          },
          {
            "key": "stationtype",
            "pattern": "GW1000|GW1100"
          }
        ]
      },
      {
        "name": "ws90_or_wh90_array",
        "match_any_keys": [
          "ws90_ver",
          "ws90cap_volt",
          "wh90batt",
          "rrain_piezo",
          "yrain_piezo"
        ]
      },
      {
        "name": "piezo_rain",
        "match_any_keys": [
          "rrain_piezo",
          "erain_piezo",
          "hrain_piezo",
          "last24hrain_piezo",
          "drain_piezo",
          "wrain_piezo",
          "mrain_piezo",
          "yrain_piezo",
          "srain_piezo"
        ]
      },
      {
        "name": "classic_rain",
        "match_any_keys": [
          "rainratein",
          "eventrainin",
          "hourlyrainin",
          "dailyrainin",
          "weeklyrainin",
          "monthlyrainin",
          "yearlyrainin",
          "totalrainin",
          "rainratemm",
          "dailyrainmm",
          "yearlyrainmm"
        ]
      },
      {
        "name": "extra_temp_humidity",
        "match_any_key_regex": [
          "^temp[1-8][fc]$",
          "^humidity[1-8]$",
          "^batt[1-8]$"
        ]
      },
      {
        "name": "temperature_probe_wn34_like",
        "match_any_key_regex": [
          "^tf_ch[1-8]c?$",
          "^tf_batt[1-8]$"
        ]
      },
      {
        "name": "soil_moisture",
        "match_any_key_regex": [
          "^soilmoisture([1-9]|1[0-6])$",
          "^soilbatt([1-9]|1[0-6])$",
          "^soilad([1-9]|1[0-6])$"
        ]
      },
      {
        "name": "pm25_sensor",
        "match_any_key_regex": [
          "^pm25_ch[1-8]$",
          "^pm25_avg_24h_ch[1-8]$",
          "^pm25batt[1-8]$"
        ]
      },
      {
        "name": "co2_air_quality",
        "match_any_keys": [
          "tf_co2",
          "tf_co2c",
          "humi_co2",
          "pm25_co2",
          "pm25_24h_co2",
          "pm10_co2",
          "pm10_24h_co2",
          "co2",
          "co2_24h",
          "co2_batt"
        ]
      },
      {
        "name": "lightning",
        "match_any_keys": [
          "lightning",
          "lightning_mi",
          "lightning_num",
          "lightning_time",
          "wh57batt"
        ]
      },
      {
        "name": "leaf_wetness",
        "match_any_key_regex": [
          "^leafwetness_ch[1-8]$",
          "^leaf_batt[1-8]$"
        ]
      },
      {
        "name": "leak_detection",
        "match_any_key_regex": [
          "^leak_ch[1-8]$",
          "^leakbatt[1-8]$"
        ]
      },
      {
        "name": "laser_distance_lds01_experimental",
        "match_any_key_regex": [
          "^lds",
          "^laser",
          "^depth",
          "^air_ch",
          "^thi_ch",
          "^data[0-9]+num"
        ]
      }
    ]
  },
  "unknown_raw_keys": {
    "enabled": true,
    "output_key": "unknown_raw_keys",
    "include_in_latest_json": true,
    "log_each_new_key": true,
    "ignore_keys": [
      "PASSKEY"
    ],
    "ignore_key_regex": [
      "^_",
      "^debug_"
    ],
    "known_keys_are_collected_from": [
      "profile.metadata_fields",
      "fields.*.sources",
      "dynamic_sensors.*.fields",
      "known_raw_keys"
    ],
    "recommended_log_message": "Unknown Ecowitt raw key detected; add it to ecowitt-map.json if useful."
  },
  "known_raw_keys": [
    "PASSKEY",
    "stationtype",
    "runtime",
    "heap",
    "dateutc",
    "freq",
    "model",
    "interval",
    "softwaretype",
    "runtimetxt",
    "gustold"
  ],
